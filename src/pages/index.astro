---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CALCULATEURS, SIMULATEUR, GUIDES } from "../lib/site-nav";

const title = "Calculateurs fiscaux gratuits et open source — Clairfisc";
const description =
  "Calculateurs fiscaux gratuits : dividendes étrangers (2047), plus-values de cession (2074) et crypto (2086), comptes étrangers (3916), PFU ou barème. Calcul 100 % local dans votre navigateur, open source, sans compte ni tracker.";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto w-full max-w-5xl px-4 py-10">
    <section class="max-w-3xl">
      <h1 class="text-3xl font-bold text-slate-900">Calculateurs fiscaux gratuits</h1>
      <p class="mt-3 text-slate-600">
        Des outils clairs pour votre déclaration de revenus, dont les règles et le code sont
        publics. <strong>Calcul 100 % local</strong> dans votre navigateur&nbsp;: aucune donnée ne
        part, zéro compte, zéro tracker.
      </p>
    </section>

    <h2 class="mt-10 mb-4 text-base font-semibold text-slate-900">Les calculateurs</h2>
    <ul class="grid gap-4 sm:grid-cols-2">
      {
        CALCULATEURS.map((l) => (
          <li>
            <a
              href={l.href}
              class="block h-full rounded-lg border border-slate-200 bg-white p-5 transition hover:border-blue-300 hover:shadow-sm"
            >
              <span class="font-semibold text-slate-900">{l.long}</span>
              <span class="mt-1 block text-sm text-slate-600">{l.resume}</span>
            </a>
          </li>
        ))
      }
    </ul>

    <h2 class="mt-10 mb-1 text-base font-semibold text-slate-900">Simulateur d'arbitrage</h2>
    <p class="mb-4 max-w-3xl text-sm text-slate-600">
      Des outils de décision « avant chaque choix » : ils comparent deux scénarios chiffrés (faire / ne
      pas faire) sans rien recommander. Aide informative, pas un conseil fiscal.
    </p>
    <ul class="grid gap-4 sm:grid-cols-2">
      {
        SIMULATEUR.map((l) => (
          <li>
            <a
              href={l.href}
              class="block h-full rounded-lg border border-slate-200 bg-white p-5 transition hover:border-blue-300 hover:shadow-sm"
            >
              <span class="font-semibold text-slate-900">{l.long}</span>
              <span class="mt-1 block text-sm text-slate-600">{l.resume}</span>
            </a>
          </li>
        ))
      }
    </ul>

    <h2 class="mt-10 mb-4 text-base font-semibold text-slate-900">Guides</h2>
    <ul class="grid gap-4 sm:grid-cols-2">
      {
        GUIDES.map((l) => (
          <li>
            <a
              href={l.href}
              class="block h-full rounded-lg border border-slate-200 bg-white p-5 transition hover:border-blue-300 hover:shadow-sm"
            >
              <span class="font-semibold text-slate-900">{l.long}</span>
              <span class="mt-1 block text-sm text-slate-600">{l.resume}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
