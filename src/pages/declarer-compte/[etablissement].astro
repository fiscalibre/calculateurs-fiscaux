---
import "../../styles/global.css";
import Disclaimer from "../../components/content/Disclaimer.astro";
import { ETABLISSEMENTS, evalueCompte, type Etablissement } from "../../lib/comptes-3916";

/** Une page SEO par établissement (longue traîne « déclarer compte {X} impôts », §14.7.6). */
export function getStaticPaths() {
  return ETABLISSEMENTS.map((etab) => ({
    params: { etablissement: etab.id },
    props: { etab },
  }));
}

interface Props {
  etab: Etablissement;
}
const { etab } = Astro.props as Props;

// Verdict « par défaut » pour ce type d'établissement (réutilise le moteur → cohérence).
const r = evalueCompte({ type: etab.typeParDefaut, etablissementId: etab.id });
const estCrypto = etab.formulaireParDefaut === "3916-bis";
const verdictTexte =
  r.verdict === "a_declarer"
    ? `Oui, en principe à déclarer`
    : r.verdict === "exonere"
      ? `Potentiellement dispensé`
      : `À vérifier`;

const title = `Déclarer son compte ${etab.designation} aux impôts (3916${estCrypto ? " / 3916-bis" : ""}) — 2026`;
const description = `Faut-il déclarer votre compte ${etab.designation} aux impôts ? ${verdictTexte}. Formulaire ${etab.formulaireParDefaut}, règles, amendes et fiche à recopier. Outil gratuit, 100 % local.`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og-default.png", Astro.site).href;
const lienOutil = "/comptes-etrangers-3916";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <main class="mx-auto w-full max-w-3xl px-4 py-8">
      <article class="flex flex-col gap-4 text-slate-700">
        <header>
          <h1 class="text-2xl font-bold text-slate-900">
            Faut-il déclarer votre compte {etab.designation} aux impôts&nbsp;?
          </h1>
          <p class="mt-1 text-sm text-slate-500">
            {etab.pays ? `Établissement situé : ${etab.pays}. ` : ""}Formulaire {etab.formulaireParDefaut}
            {estCrypto ? " (comptes d'actifs numériques)" : ""}.
          </p>
        </header>

        <p class="rounded-md border border-amber-300 bg-amber-100 px-3 py-2 text-amber-900">
          <strong>{verdictTexte}.</strong> {r.motif}
        </p>

        {etab.note && <p class="rounded-md bg-slate-100 px-3 py-2 text-sm italic">{etab.note}</p>}

        {estCrypto && etab.codePsan && (
          <p>
            Sur le formulaire <strong>3916-bis</strong>, {etab.designation} correspond au code PSAN
            <strong> {etab.codePsan}</strong> (liste officielle des plateformes).
          </p>
        )}

        <h2 class="mt-2 text-lg font-semibold text-slate-900">Le principe</h2>
        <p>
          Depuis 2019, un résident fiscal français doit déclarer <strong>tout compte ouvert, détenu, utilisé ou
          clos à l'étranger</strong> au cours de l'année — même <strong>vide ou dormant</strong>. L'obligation
          porte sur l'existence du compte, pas sur son activité. {estCrypto
            ? "Un compte d'actifs numériques se déclare même sans aucune cession."
            : "Cela vaut aussi pour les néobanques et comptes-titres tenus à l'étranger."}
        </p>

        <h2 class="mt-2 text-lg font-semibold text-slate-900">Les sanctions</h2>
        <p>
          Le défaut de déclaration coûte <strong>1 500 €</strong> par compte bancaire (10 000 € pour un État sans
          convention d'assistance) et <strong>750 €</strong> par compte d'actifs numériques&nbsp;: déclarer est
          bien moins coûteux que l'oubli.
        </p>

        <div class="mt-3 rounded-lg border border-blue-200 bg-blue-50 p-4">
          <p class="font-medium text-slate-900">Vérifiez tous vos comptes et obtenez la fiche à recopier</p>
          <p class="mt-1 text-sm">
            Notre checklist gratuite indique, pour chacun de vos comptes, s'il est à déclarer et sur quel
            formulaire, puis génère la fiche à recopier sur impots.gouv.
          </p>
          <a
            href={lienOutil}
            class="mt-3 inline-block rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-blue-700"
          >
            Ouvrir la checklist comptes étrangers →
          </a>
        </div>

        <p class="text-xs text-slate-500">
          Source du verdict&nbsp;: {r.source}. Outil d'aide informative, ne remplace pas la doctrine officielle ni
          un conseil professionnel. {r.verdict === "a_verifier" ? "Ce cas n'est pas tranché : rapprochez-vous de la doctrine ou d'un professionnel." : ""}
        </p>

        <Disclaimer />
      </article>
    </main>
  </body>
</html>
